# Copy this file to `.env` and fill in the values.
# Anything prefixed with VITE_ is exposed to the browser.

# Google Analytics 4 - get from analytics.google.com -> Admin -> Data Streams
VITE_GA4_ID=

# Meta (Facebook) Pixel - get from Meta Events Manager
VITE_META_PIXEL=

# Optional Umami analytics (already wired in index.html)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
